# ===========================================
# SatyaSetu.AI Backend — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Database (Required) ---
# Neon PostgreSQL connection string
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-rapid-queen-akdht2e7-pooler.c-3.us-west-2.aws.neon.tech/neondb?sslmode=require

# --- JWT Authentication (Optional — has default) ---
# Change this in production for security!
JWT_SECRET=change-this-to-a-random-secret-string

# --- AI Copilot (Required for copilot feature) ---
# Get your key at https://console.groq.com/keys
Groq_api=your_groq_api_key_here

# --- CORS (Optional — defaults to allow all) ---
# Comma-separated list of allowed frontend origins
# Use * to allow all (default), or restrict for production:
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# --- OSINT API Keys (Optional — features degrade gracefully without them) ---
VT_API_KEY=
ABUSEIPDB_KEY=
WHOIS_KEY=
